{
  "name": "screenshot-ocr-demo",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "electron ."
  },
  "dependencies": {
    "axios": "^1.6.8",
    "screenshot-desktop": "^1.15.0",
    "tree-kill": "^1.2.2"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.screenshot.ocr.demo",
    "productName": "Screenshot OCR Demo",
    "directories": {
      "output": "dist"
    },
    "extraResources": [
      {
        "from": "../backend/dist_backend/backend",
        "to": "backend_exe"
      },
      {
        "from": "../frontend/dist",
        "to": "frontend/dist"
      }
    ],
    "win": {
      "target": ["zip", "nsis"]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}